# ─── PostgreSQL ────────────────────────────────────────────
# Local dev
# DATABASE_URL=postgresql://postgres:root@localhost:5432/ecommerce_dashboard
DATABASE_URL=


# Cloud SQL Unix socket (uncomment for Cloud Run)
# DATABASE_URL=postgresql://postgres:your_password@/ecommerce?host=/cloudsql/PROJECT:REGION:INSTANCE

# Cloud SQL TCP with SSL (uncomment for direct IP access)
# DATABASE_URL=postgresql://postgres:your_password@34.x.x.x:5432/ecommerce
DB_SSL=true

# ─── Google Cloud ──────────────────────────────────────────
GOOGLE_CLOUD_PROJECT_ID=bigquery-ecommerce-489218
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json

# ─── Pub/Sub ───────────────────────────────────────────────
PUBSUB_TOPIC=purchase-events

# ─── BigQuery ──────────────────────────────────────────────
BIGQUERY_DATASET=ecommerce_analytics
BIGQUERY_TABLE=purchases

# ─── Server ────────────────────────────────────────────────
PORT=5000
FRONTEND_URL=http://localhost:3000
